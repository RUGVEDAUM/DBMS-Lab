Q] Design a trigger to stop insertion or updation in the table for the days like sat or sun of any date (for practice purpose take the day as 'tue')

CREATE OR REPLACE TRIGGER no_ins_upd
BEFORE INSERT OR UPDATE ON emp2
FOR EACH ROW
DECLARE
    v_day varchar2(10);
begin
    v_day := to_char(sysdate, 'dy');
    if v_day='tue' then
       raise_application_error(-20001, 'cant insert or update on the table on ' || v_day);
    end if;
end;
/
