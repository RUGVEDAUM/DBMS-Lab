Q1] create a table emp2 with fields empno as int, name as character, category as int (take only 3 categories i.e. 1, 2, & 3)

CREATE TABLE emp2 (
    empno INT,
    name VARCHAR2(50),
    category INT CHECK (category IN (1, 2, 3))
);

Q2. Design a trigger for insertion or update a new record in capital letters only (hint: name=upper(name))

CREATE OR REPLACE TRIGGER trg_emp2_upper
BEFORE INSERT OR UPDATE ON emp2
FOR EACH ROW
BEGIN
    :NEW.name := UPPER(:NEW.name);
END;
/

Q3. Add another field salary as number to the table 

ALTER TABLE emp2
ADD salary NUMBER;

Q4. Design a trigger for insertion or updation for the following
    if category is 1 then salary should be more than 10000
    if category is 2 then salary should be more than 20000
    if category is 3 then salary should be more than 30000

CREATE OR REPLACE TRIGGER trg_emp2_salary_check
BEFORE INSERT OR UPDATE ON emp2
FOR EACH ROW
BEGIN
    CASE :NEW.category
        WHEN 1 THEN
            IF :NEW.salary <= 10000 THEN
                RAISE_APPLICATION_ERROR(-20001, 'Salary must be greater than 10000 for category 1');
            END IF;
        WHEN 2 THEN
            IF :NEW.salary <= 20000 THEN
                RAISE_APPLICATION_ERROR(-20002, 'Salary must be greater than 20000 for category 2');
            END IF;
        WHEN 3 THEN
            IF :NEW.salary <= 30000 THEN
                RAISE_APPLICATION_ERROR(-20003, 'Salary must be greater than 30000 for category 3');
            END IF;
    END CASE;
END;
/

