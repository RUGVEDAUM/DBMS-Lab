);
o/p: table altered 

desc emp2_Aud;
o/p:  Name                                      Null?    Type
 ----------------------------------------- -------- ----------------------------
 EMPNO                                              NUMBER
 NAME                                               VARCHAR2(50)
 CATEGORY                                           NUMBER
 SALARY                                             NUMBER
 OLD_SALARY                                         NUMBER
 MODIFIED_DATE                                      DATE 

CREATE OR REPLACE TRIGGER emp2_Aud_Trig
AFTER UPDATE OF salary ON emp2
FOR EACH ROW
BEGIN
    INSERT INTO emp2_Aud (
        empno,
        name,
        category,
        salary,
        old_salary,
        modified_date
    )
    VALUES (
        :OLD.empno,
        :OLD.name,
        :OLD.category,
        :OLD.salary,      -- old salary stored in salary column
        :OLD.salary,      -- old salary again (as per your requirement)
        SYSDATE
    );
END;
/ 

