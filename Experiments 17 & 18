CREATE OR REPLACE TRIGGER aud_sal
AFTER UPDATE OF salary ON emp2
FOR EACH ROW
BEGIN
    INSERT INTO emp2_aud1 
    (empno, name, category, salary, new_salary, modified_date)
    VALUES 
    (:OLD.empno, :OLD.name, :OLD.category, :OLD.salary, :NEW.salary, SYSDATE);
END;
